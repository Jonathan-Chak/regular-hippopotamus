---
const {pathname} = Astro.url;

const navLinks = [
  { name: '♘HOME', href: '/' },
  { name: 'WIP', href: '/wip' },
];

const isActive = (href: string) => 
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="w-full h-10 mb-11">
  <nav class="w-full h-15 fixed top-0 to-gray-900 bg-linear-to-b from-blue-900 via-gray-800 via-30%">
    <ul class="flex pt-3">
      {navLinks.map((link)=>(
        <li>
          <a
          href={link.href}
          aria-current={isActive(link.href) ? "page" : null}
          class="text-2xl px-15 font- text-neutral-500  aria-[current=page]:text-white aria-[current=page]:font-bold ">
            {link.name}
          </a> 
        </li>
      ))} 
    </ul>
  </nav>
</header>
